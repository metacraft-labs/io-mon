nimcache/
build/
*.exe
*.dll
*.so
*.dylib
*.pdb
*.obj
*.o
*.a
*.lib
*.exp
test-logs/

# Compiled test binaries (nim c -r leaves the binary next to its source).
# Tests live under per-OS subdirs (tests/portable, tests/posix, tests/macos,
# tests/linux, tests/windows); the binary has the same name as the .nim source
# minus the extension. Ignore the binaries, keep the sources.
tests/*/test_*
!tests/*/test_*.nim
